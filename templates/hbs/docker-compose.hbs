# ============================================================
# {{project}}
# ============================================================
# Generated by `airis gen` - DO NOT EDIT MANUALLY
# Source of truth: manifest.toml
#
# Use `airis up` to start. Profiles control which services run.
# ============================================================

services:
{{#each services}}
  {{name}}:
{{#if container_name}}
    container_name: {{container_name}}
{{/if}}
{{#if build}}
    build:
      context: {{build.context}}
{{#if build.dockerfile}}
      dockerfile: {{build.dockerfile}}
{{/if}}
{{#if build.target}}
      target: {{build.target}}
{{/if}}
{{else}}
    image: {{image}}
{{/if}}
{{#if working_dir}}
    working_dir: {{working_dir}}
{{/if}}
{{#if gpu}}
    deploy:
      resources:
        reservations:
          devices:
            - driver: {{gpu.driver}}
              count: {{gpu.count}}
              capabilities: [{{#each gpu.capabilities}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}]
{{else if deploy}}
    deploy:
      replicas: {{deploy.replicas}}
{{/if}}
{{#if command}}
    command: {{{command}}}
{{/if}}
{{#if profiles}}
    profiles:
{{#each profiles}}
      - "{{this}}"
{{/each}}
{{/if}}
{{#if depends_on}}
    depends_on:
{{#each depends_on}}
      - {{this}}
{{/each}}
{{/if}}
{{#if ports}}
    ports:
{{#each ports}}
      - "{{this}}"
{{/each}}
{{/if}}
{{#if extra_hosts}}
    extra_hosts:
{{#each extra_hosts}}
      - "{{this}}"
{{/each}}
{{/if}}
{{#if env}}
    environment:
{{#each env}}
      {{@key}}: "{{this}}"
{{/each}}
{{/if}}
{{#if volumes}}
    volumes:
{{#each volumes}}
      - {{this}}
{{/each}}
{{/if}}
{{#if shm_size}}
    shm_size: "{{shm_size}}"
{{/if}}
{{#if restart}}
    restart: {{restart}}
{{/if}}
{{#if runtime}}
    runtime: {{runtime}}
{{/if}}
{{#if devices}}
    devices:
{{#each devices}}
      - {{this}}
{{/each}}
{{/if}}
{{#if network_mode}}
    network_mode: {{network_mode}}
{{/if}}
{{#if labels}}
    labels:
{{#each labels}}
      - "{{this}}"
{{/each}}
{{/if}}
{{#if networks}}
    networks:
{{#each networks}}
      - {{this}}
{{/each}}
{{/if}}
{{#if health_path}}
    healthcheck:
      test: ["CMD-SHELL", "node -e \"require('http').request({hostname:'localhost',port:{{port}},path:'{{health_path}}',timeout:5000},(r)=>{process.exit(r.statusCode===200?0:1)}).on('error',()=>process.exit(1)).end()\""]
      interval: {{#if health_interval}}{{health_interval}}{{else}}30s{{/if}}
      timeout: {{#if health_timeout}}{{health_timeout}}{{else}}10s{{/if}}
      retries: {{#if health_retries}}{{health_retries}}{{else}}3{{/if}}
      start_period: {{#if health_start_period}}{{health_start_period}}{{else}}40s{{/if}}
{{/if}}

{{/each}}

{{#if network_defs}}
networks:
  default:
    name: {{project}}_default
    external: {{default_external}}
{{#each network_defs}}
  {{@key}}:
    external: {{this.external}}
{{#if this.name}}
    name: {{this.name}}
{{/if}}
{{/each}}
{{else}}
networks:
  default:
    name: {{project}}_default
    external: {{default_external}}
  traefik:
    name: traefik_default
    external: true
{{#if proxy_network}}
  {{proxy_network}}:
    external: true
{{/if}}
{{/if}}

volumes:
{{#each volume_names}}
  {{this}}:
{{/each}}
